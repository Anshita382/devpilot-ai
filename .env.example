# DevPilot AI configuration. Copy to `.env` and adjust as needed.
# All variables are prefixed DEVPILOT_ and are optional — every one has a
# zero-config default so the system runs out of the box in mock mode.

# --- run mode: mock | local | api ---
# mock  : deterministic agents, no LLM, no external services (default)
# local : uses Ollama at DEVPILOT_OLLAMA_BASE_URL
# api   : uses a hosted provider if a key below is set
DEVPILOT_MODE=mock

# --- database (defaults to a local SQLite file when unset) ---
# For Postgres + pgvector (docker compose path):
# DEVPILOT_DATABASE_URL=postgresql+psycopg://devpilot:devpilot@localhost:5432/devpilot

# --- redis (optional) ---
# DEVPILOT_REDIS_URL=redis://localhost:6379/0

# --- local LLM (mode=local) ---
DEVPILOT_OLLAMA_BASE_URL=http://localhost:11434
DEVPILOT_OLLAMA_MODEL=qwen2.5-coder:7b

# --- hosted LLM (mode=api) ---
# DEVPILOT_OPENAI_API_KEY=sk-...
# DEVPILOT_ANTHROPIC_API_KEY=sk-ant-...
DEVPILOT_API_MODEL=gpt-4o-mini

# --- retrieval tuning ---
DEVPILOT_TOP_K=8
DEVPILOT_HYBRID_ALPHA=0.5

# --- agents ---
DEVPILOT_MAX_REPAIR_ITERATIONS=3
DEVPILOT_REQUIRE_PLAN_APPROVAL=false
DEVPILOT_SANDBOX_TIMEOUT_SECONDS=120

# --- sandbox backend: subprocess | docker ---
# DEVPILOT_SANDBOX=subprocess
